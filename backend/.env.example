# Backend Configuration
PORT=3001

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Doku Payment Gateway
DOKU_CLIENT_ID=your-client-id
DOKU_SECRET_KEY=your-secret-key
QRIS_PROVIDER=doku

# Pawoon POS
PAWOON_CLIENT_ID=your-client-id
PAWOON_CLIENT_SECRET=your-client-secret
PAWOON_OUTLET_ID=your-outlet-id
PAWOON_BASE_URL=https://open-api.pawoon.com

# WhatsApp
WACLI_BIN=/path/to/wacli
WHATSAPP_SEND_QRIS_ON_CREATE=true
WHATSAPP_NOTIFY_QRIS_SUCCESS=true

# Delivery
COURIER_PHONES=+628xxx,+628yyy

# Dashboard
DASHBOARD_JWT_SECRET=your-jwt-secret

# Queue
AUTO_PROCESS_QUEUE=true
ORDER_WEBHOOK_URL=http://localhost:3001/webhooks/orders
BACKEND_API_KEY=your-api-key

# Public
PUBLIC_BASE_URL=https://your-domain.com
